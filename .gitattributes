# Set default behavior to automatically normalize line endings
* text=auto

# Explicitly declare text files you want to always be normalized and converted to native line endings on checkout.
*.js     text
*.ts     text
*.tsx    text
*.css    text
*.md     text
*.json   text
*.mjs    text
*.d.ts   text
*.env*   text
*.gitignore text
*.gitattributes text

# Declare binary files to be excluded from line ending normalization
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.svg    binary
*.mp3    binary
*.mp4    binary
*.wav    binary
*.ogg    binary
*.webp   binary
*.pdf    binary
